---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<span class="prompt">
			<span class="prompt-user">~</span><span class="prompt-sep">/</span><a href="/" class="prompt-title">{SITE_TITLE}</a>
		</span>
		<div class="nav-links">
			<HeaderLink href="/">home</HeaderLink>
			<HeaderLink href="/blog">blog</HeaderLink>
			<HeaderLink href="/about">about</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		border-bottom: 1px solid var(--border);
		background: var(--bg-alt);
		padding: 0 1.5rem;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 700px;
		margin: 0 auto;
		height: 3rem;
	}
	.prompt {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.9rem;
		display: flex;
		align-items: center;
		gap: 0;
	}
	.prompt-user {
		color: var(--green);
	}
	.prompt-sep {
		color: var(--fg-dim);
		margin: 0 0.1rem;
	}
	.prompt-title {
		color: var(--mauve);
		font-weight: 700;
		border-bottom: none;
	}
	.prompt-title:hover {
		color: var(--pink);
		border-bottom: none;
	}
	.nav-links {
		display: flex;
		gap: 1.5rem;
		align-items: center;
	}
	.nav-links :global(a) {
		color: var(--fg-muted);
		font-size: 0.85rem;
		text-decoration: none;
		border-bottom: none;
		transition: color 0.15s;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--teal);
		border-bottom: none;
	}
</style>
