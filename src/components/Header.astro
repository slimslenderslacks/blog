---
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname.replace(base, '');
const isActive = (path: string) =>
	path === '/' ? pathname === '/' || pathname === '' : pathname.startsWith(path);
---

<header>
	<nav>
		<span class="prompt">
			<span class="prompt-user">~</span><span class="prompt-sep">/</span><a href={`${base}/`} class="prompt-title">{SITE_TITLE}</a>
		</span>
		<div class="nav-links">
			<a href={`${base}/`} class:list={[{ active: isActive('/') }]}>home</a>
			<a href={`${base}/posts`} class:list={[{ active: isActive('/posts') }]}>blog</a>
			<a href={`${base}/about`} class:list={[{ active: isActive('/about') }]}>about</a>
		</div>
	</nav>
</header>

<style>
	header {
		border-bottom: 1px solid var(--border);
		background: var(--bg-alt);
		padding: 0 1.5rem;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 700px;
		margin: 0 auto;
		height: 3rem;
	}
	.prompt {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.9rem;
		display: flex;
		align-items: center;
	}
	.prompt-user { color: var(--green); }
	.prompt-sep { color: var(--fg-dim); margin: 0 0.1rem; }
	.prompt-title {
		color: var(--mauve);
		font-weight: 700;
		border-bottom: none;
	}
	.prompt-title:hover { color: var(--pink); border-bottom: none; }
	.nav-links {
		display: flex;
		gap: 1.5rem;
		align-items: center;
	}
	.nav-links a {
		color: var(--fg-muted);
		font-size: 0.85rem;
		text-decoration: none;
		border-bottom: none;
		transition: color 0.15s;
	}
	.nav-links a:hover,
	.nav-links a.active {
		color: var(--teal);
		border-bottom: none;
	}
</style>
