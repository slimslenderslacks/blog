---
const today = new Date();
---
<footer>
	<span class="dim">—</span>
	<a href="https://github.com/slimslenderslacks" target="_blank">github</a>
	<span class="dim">·</span>
	<span class="dim">{today.getFullYear()}</span>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 1.25rem 1.5rem;
		text-align: center;
		font-size: 0.8rem;
		color: var(--fg-dim);
		background: var(--bg-alt);
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}
	footer a {
		color: var(--fg-dim);
		border-bottom: none;
		transition: color 0.15s;
	}
	footer a:hover {
		color: var(--teal);
		border-bottom: none;
	}
	.dim { color: var(--fg-dim); }
</style>
