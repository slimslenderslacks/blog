---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<header class="post-header">
					<p class="post-meta">
						<span class="dim">posted</span>
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<>
								<span class="dim">· updated</span>
								<FormattedDate date={updatedDate} />
							</>
						)}
					</p>
					<h1 class="post-title">{title}</h1>
					<hr />
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
			<p class="back"><a href={`${base}/posts`}>← back to posts</a></p>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-header { margin-bottom: 2rem; }
	.post-meta {
		color: var(--fg-dim); font-size: 0.8rem; margin: 0 0 0.5rem;
		display: flex; gap: 0.4rem; flex-wrap: wrap;
	}
	.post-meta :global(time) { color: var(--yellow); }
	.post-title { font-size: 1.6rem; color: var(--pink); margin: 0; }
	.post-title::before { content: none; }
	hr { margin: 1.25rem 0 0; border-color: var(--border); }
	.prose { color: var(--fg); }
	.prose :global(h1)::before { content: '# '; color: var(--fg-dim); }
	.back { margin-top: 3rem; font-size: 0.85rem; }
	.back a { color: var(--fg-dim); border-bottom: none; }
	.back a:hover { color: var(--teal); border-bottom: none; }
	.dim { color: var(--fg-dim); }
</style>
