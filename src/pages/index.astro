---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="intro">
				<p class="greeting"><span class="dim">$</span> whoami</p>
				<p>slimslenderslacks — writing about software, tools, and ideas.</p>
			</div>

			<section class="recent">
				<p class="section-label"><span class="dim">$</span> ls -lt posts/ <span class="dim"># recent</span></p>
				<ul>
					{posts.map((post) => (
						<li>
							<span class="date"><FormattedDate date={post.data.pubDate} /></span>
							<a href={`${base}/posts/${post.id}/`}>{post.data.title}</a>
						</li>
					))}
				</ul>
				<p class="more"><a href={`${base}/posts`}>→ all posts</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro { margin-bottom: 2.5rem; }
	.greeting { color: var(--fg-dim); margin-bottom: 0.25rem; }
	.intro p:last-child { color: var(--fg-muted); margin: 0; }
	.section-label { color: var(--fg-dim); font-size: 0.85rem; margin-bottom: 0.75rem; }
	ul { list-style: none; padding: 0; margin: 0 0 1rem; }
	li { display: flex; gap: 1.5rem; align-items: baseline; padding: 0.2rem 0; }
	.date { color: var(--fg-dim); font-size: 0.8rem; white-space: nowrap; min-width: 9rem; }
	li a { color: var(--fg); border-bottom: none; }
	li a:hover { color: var(--teal); border-bottom: none; }
	.more { font-size: 0.85rem; margin-top: 0.75rem; }
	.more a { color: var(--mauve); }
	.dim { color: var(--fg-dim); }
</style>
